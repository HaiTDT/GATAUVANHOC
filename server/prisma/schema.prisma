generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER // Keep CUSTOMER/STUDENT conceptually same for auth compatibility
  ADMIN // Keep ADMIN for teachers/admins
}

enum SubmissionStatus {
  PENDING
  GRADED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String?
  phone        String?
  birthday     DateTime?
  gender       String?
  avatar       String?
  googleId     String?
  role         Role     @default(CUSTOMER)
  
  submissions      Submission[]
  learningProgress LearningProgress[]
  favoriteLessons  FavoriteLesson[]
  addresses        Address[]
  enrollments      Enrollment[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Address {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName        String
  phone           String
  province        String
  district        String
  ward            String
  detail          String
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("addresses")
}

model Course {
  id          String      @id @default(uuid())
  title       String
  slug        String      @unique
  description String?     @db.Text
  content     String?     @db.Text
  price       Float       @default(0)
  imageUrl    String?
  isActive    Boolean     @default(true)
  
  assignments Assignment[]
  enrollments Enrollment[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("courses")
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  status    EnrollmentStatus @default(PENDING)
  amount    Float
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  PENDING
  PAID
  CANCELLED
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  lessons     Lesson[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("categories")
}

model Lesson {
  id          String      @id @default(uuid())
  title       String
  slug        String      @unique
  description String?
  content     String?     @db.Text
  videoUrl    String?
  imageUrl    String?
  isActive    Boolean     @default(true)
  
  grade       Int?
  
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  assignments      Assignment[]
  favoriteLessons  FavoriteLesson[]
  learningProgress LearningProgress[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([categoryId])
  @@index([grade])
  @@map("lessons")
}

enum AssignmentType {
  ESSAY
  QUIZ
}

model Assignment {
  id          String         @id @default(uuid())
  title       String
  description String?
  content     String         @db.Text
  type        AssignmentType @default(ESSAY)
  points      Int            @default(10)
  dueDate     DateTime?
  duration    Int?           // Duration in minutes for timed quizzes
  
  lessonId    String?
  lesson      Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  
  courseId    String?
  course      Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  questions   Question[]
  submissions Submission[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([lessonId])
  @@index([courseId])
  @@map("assignments")
}

model Question {
  id           String      @id @default(uuid())
  assignmentId String
  assignment   Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  text         String      @db.Text
  type         QuestionType @default(MULTIPLE_CHOICE)
  points       Int         @default(1)
  order        Int         @default(0)
  
  options      QuestionOption[]
  answers      SubmissionAnswer[]
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("questions")
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  ESSAY
}

model QuestionOption {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  
  @@map("question_options")
}

model Submission {
  id           String   @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  content      String?  @db.Text // Legacy support or overall summary
  status       SubmissionStatus @default(PENDING)
  score        Float?
  teacherComment String? @db.Text
  attemptNumber Int      @default(1)
  
  answers      SubmissionAnswer[]
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([assignmentId])
  @@map("submissions")
}

model SubmissionAnswer {
  id           String   @id @default(uuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  answerText   String?  @db.Text
  optionId     String?  // For MCQ
  isCorrect    Boolean? // Cached result for MCQ
  
  @@map("submission_answers")
}

model LearningProgress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  isCompleted Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("learning_progress")
}

model FavoriteLesson {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("favorite_lessons")
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  excerpt   String?
  content   String   @db.Text
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blogs")
}
model Banner {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  imageUrl    String
  linkUrl     String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("banners")
}
